// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String?  // Prénom
  lastName  String?  // Nom
  phone     String?  // Téléphone personnel
  isFounder Boolean  @default(false) // Membre fondateur?
  role      Role     @default(ARTIST)

  // Premium/Subscription fields
  plan              SubscriptionType @default(FREE)
  subscriptionEndsAt DateTime?      // Date fin abonnement
  trialEndsAt       DateTime?       // Date fin période d'essai

  profile   Profile?
  sentMessages     Message[] @relation("MessageSender")
  notifications    Notification[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String   // Nom d'affichage universel (source unique de vérité)
  bio         String?
  avatar      String?  // Base64 pour le début
  location    String?
  website     String?
  socialLinks Json?    // {instagram: "", facebook: "", etc}
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist      Artist?
  venue       Venue?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profiles")
}

model Artist {
  id              String   @id @default(cuid())
  profileId       String   @unique

  // General information (identity) - artistName synchronisé avec Profile.name
  coverPhoto      String?     // Photo de couverture/bannière (base64)
  logo            String?     // Logo/image d'identité (base64)
  baseLocation    String?     // Ville/Pays de base (différent du location du profil)
  foundedYear     Int?        // Année de création/début de carrière

  // Basic info
  genres          String[]
  instruments     String[]
  priceRange      String?     // "100-500", "500-1000", etc
  experience      String?     // "BEGINNER", "INTERMEDIATE", "PROFESSIONAL"
  yearsActive     Int?        // Années d'expérience

  // Extended profile fields
  artisticBio     String?     // Bio artistique détaillée
  specialties     String[]    // Spécialités (concert, studio, teaching, etc)
  equipment       String[]    // Équipements possédés
  requirements    String[]    // Équipements requis de la venue
  
  // Pricing & Conditions
  priceDetails    Json?       // {concert: 500, private: 800, conditions: "..."}
  travelRadius    Int?        // Rayon de déplacement en km
  
  // Media & Portfolio
  portfolio       Json?       // {photos: [], videos: [], audio: []}
  socialLinks     Json?       // {spotify: "", soundcloud: "", youtube: "", instagram: ""}
  mediaLinks      Json?       // Links externes vers plateformes
  
  // Availability & Settings
  availability    Json?       // Calendar data
  isPublic        Boolean     @default(false)  // Profil public visible
  publicSlug      String?     // Pour URL publique /p/slug
  artistDescription String?   // Description courte pour la page publique
  
  // Group/Solo Management
  artistType      ArtistType       @default(SOLO)  // Type d'artiste (solo, groupe, etc)
  artistDiscipline ArtistDiscipline?               // Discipline artistique
  memberCount     Int              @default(1)     // Nombre de membres
  
  // Relations
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  events          Event[]
  members         ArtistMember[]
  metrics         ArtistMetrics? @relation("ArtistMetrics")
  metricsEvents   ArtistMetricsEvent[] @relation("ArtistMetricsEvents")
  bookingRequests BookingRequest[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("artists")
}

model ArtistMember {
  id          String   @id @default(cuid())
  artistId    String

  // Personal Info
  artistName  String                      // Nom de scène du membre
  firstName   String?                     // Prénom civil
  lastName    String?                     // Nom civil
  role        String?                     // Rôle dans le groupe (chanteur, guitariste, etc)
  bio         String?                     // Bio personnelle du membre
  avatar      String?                     // Photo du membre (base64)
  
  // Contact & Social
  email       String?                     // Email personnel du membre
  phone       String?                     // Téléphone personnel
  socialLinks Json?                       // {instagram: "", facebook: "", twitter: ""}
  
  // Musical Info
  instruments String[]                    // Instruments joués par ce membre
  experience  String?                     // Niveau d'expérience du membre
  yearsActive Int?                        // Années d'expérience du membre
  
  // Member Status
  isFounder   Boolean  @default(false)    // Membre fondateur
  joinDate    DateTime @default(now())    // Date d'adhésion au groupe
  isActive    Boolean  @default(true)     // Membre actif ou non
  
  // Relations
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("artist_members")
}

model ArtistMetrics {
  id        String   @id @default(cuid())
  artistId  String   @unique
  artist    Artist   @relation("ArtistMetrics", fields: [artistId], references: [id], onDelete: Cascade)

  // Compteurs totaux
  profileViews      Int @default(0)  // Total vues du profil
  searchClicks      Int @default(0)  // Clics depuis la recherche
  venueRequests     Int @default(0)  // Demandes reçues de venues

  // Tendances mensuelles (pour calcul de variation %)
  viewsThisMonth    Int @default(0)
  viewsLastMonth    Int @default(0)
  clicksThisMonth   Int @default(0)
  clicksLastMonth   Int @default(0)
  requestsThisMonth Int @default(0)
  requestsLastMonth Int @default(0)

  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("artist_metrics")
}

model ArtistMetricsEvent {
  id          String   @id @default(cuid())
  artistId    String
  artist      Artist   @relation("ArtistMetricsEvents", fields: [artistId], references: [id], onDelete: Cascade)

  eventType   MetricEventType
  source      String?  // URL source (recherche, profil public, etc.)
  venueId     String?  // Si c'est une demande de venue

  metadata    Json?    // Données supplémentaires
  createdAt   DateTime @default(now())

  @@index([artistId, eventType, createdAt])
  @@map("artist_metrics_events")
}

model Venue {
  id          String   @id @default(cuid())
  profileId   String   @unique
  capacity    Int?
  venueType   String   // "BAR", "CLUB", "THEATER", "RESTAURANT", etc
  equipment   String[] // ["sound_system", "lighting", "stage", etc]
  amenities   String[] // ["parking", "wifi", "catering", etc]
  priceRange  String?  // Budget range they typically pay
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  events      Event[]
  bookingRequests BookingRequest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("venues")
}

model Event {
  id          String        @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?     // Heure de fin du booking

  // Location info (artist self-service)
  location    String?       // Nom de la venue/lieu
  address     String?       // Adresse complète

  duration    Int?          // Duration in minutes
  budget      Float?        // Cachet négocié
  status      BookingStatus @default(CONFIRMED)
  eventType   String        // "CONCERT", "COMEDY", "THEATER", etc

  // Artist personal management
  notes       String?       // Notes privées artiste
  tags        String[]      // Tags pour catégorisation
  requirements String?      // Special requirements

  // Relations - venueId optionnel maintenant (artist-first)
  venueId     String?
  artistId    String
  venue       Venue?        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  artist      Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  messages    Message[]
  bookingRequest BookingRequest?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("events")
  @@index([artistId, date])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  eventId   String
  isRead    Boolean  @default(false)
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("messages")
}

// NOUVEAU: Demande de booking initiée par venue
model BookingRequest {
  id          String   @id @default(cuid())

  // Qui demande quoi
  venueId     String
  artistId    String

  // Détails de la demande
  eventDate   DateTime
  eventType   String   // "CONCERT", "COMEDY", etc.
  budget      Float?
  duration    Int?     // minutes
  message     String?  // Message initial de la venue

  // Workflow status
  status      BookingRequestStatus @default(PENDING)

  // Metadata
  viewedByArtist Boolean @default(false)
  respondedAt    DateTime?

  // Relations
  venue       Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  artist      Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  // Si accepté, référence à l'Event créé
  eventId     String?  @unique
  event       Event?   @relation(fields: [eventId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([artistId, status])
  @@index([venueId, status])
  @@map("booking_requests")
}

// NOUVEAU: Notifications système
model Notification {
  id          String   @id @default(cuid())

  userId      String   // Destinataire
  type        NotificationType
  title       String
  message     String

  // Context
  relatedId   String?  // ID de l'objet lié (bookingRequestId, eventId, etc.)
  relatedType String?  // "BOOKING_REQUEST", "MESSAGE", etc.

  isRead      Boolean  @default(false)
  readAt      DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

enum ArtistType {
  SOLO
  BAND
  THEATER_GROUP
  COMEDY_GROUP
  ORCHESTRA
  CHOIR
  OTHER
}

enum ArtistDiscipline {
  MUSIC
  THEATER
  ACTOR
  COMEDIENNE
  COMEDIE
  DANCE
  CIRCUS
  MAGIE
  OTHER
}

enum Role {
  ARTIST
  VENUE
  MEMBER
  ADMIN
}

enum BookingStatus {
  PENDING     // En attente de confirmation
  ACCEPTED    // Accepté par l'artiste
  REJECTED    // Refusé par l'artiste
  CONFIRMED   // Booking confirmé
  CANCELLED   // Annulé
  COMPLETED   // Passé/Terminé
}

enum SubscriptionType {
  FREE
  PREMIUM
}

enum MetricEventType {
  PROFILE_VIEW
  SEARCH_CLICK
  VENUE_REQUEST
}

enum BookingRequestStatus {
  PENDING      // Venue a envoyé, artiste n'a pas encore répondu
  VIEWED       // Artiste a vu la demande
  ACCEPTED     // Artiste a accepté → Event créé
  DECLINED     // Artiste a refusé
  CANCELLED    // Venue a annulé avant réponse
  EXPIRED      // Timeout (optionnel pour v2)
}

enum NotificationType {
  BOOKING_REQUEST_RECEIVED   // Artiste reçoit une demande
  BOOKING_REQUEST_ACCEPTED   // Venue : artiste a accepté
  BOOKING_REQUEST_DECLINED   // Venue : artiste a refusé
  NEW_MESSAGE                // Nouveau message
  BOOKING_REMINDER           // Rappel J-7, J-1
}